modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23466
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_sOFWoVbfKwHzqmLrKumeYjUMqte"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_lkgBhRMuaHZVIFpoMhCsLpgqPrD"
REVENUECAT_PROJECT_ID = "projc49d134c"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appdf3a72549b"
